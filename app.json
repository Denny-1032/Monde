{
  "expo": {
    "name": "Monde",
    "slug": "monde",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "monde",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A6E3C"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.monde.pay"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A6E3C"
      },
      "package": "com.monde.pay",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.NFC",
        "android.permission.VIBRATE"
      ],
      "softwareKeyboardLayoutMode": "pan",
      "allowBackup": false,
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "monde.app",
              "pathPrefix": "/pay"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Monde needs camera access to scan QR codes for payments."
        }
      ],
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Monde needs photo access to set your profile picture."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "38cf31ae-abcc-4e53-b444-9f7653a62884"
      }
    },
    "owner": "denny-32",
    "description": "Monde - The simplest way to send & receive money in Zambia via QR Code and Tap to Pay. Supports Airtel, MTN, Zamtel, FNB, Zanaco, and Absa.",
    "primaryColor": "#0A6E3C"
  }
}
