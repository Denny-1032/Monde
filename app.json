{
  "expo": {
    "name": "Monde",
    "slug": "monde",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "monde",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A6E3C"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.monde.pay"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A6E3C"
      },
      "package": "com.monde.pay",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.NFC",
        "android.permission.VIBRATE"
      ],
      "softwareKeyboardLayoutMode": "pan",
      "allowBackup": true,
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Monde needs camera access to scan QR codes for payments."
        }
      ],
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Monde needs photo access to set your profile picture."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "SUPABASE_URL": "process.env.EXPO_PUBLIC_SUPABASE_URL",
      "SUPABASE_ANON_KEY": "process.env.EXPO_PUBLIC_SUPABASE_ANON_KEY",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "92755b41-9a8b-45e3-8cb6-96e9250b8a59"
      }
    },
    "owner": "acecode10",
    "description": "Monde - The simplest way to send & receive money in Zambia via QR Code and Tap to Pay. Supports Airtel, MTN, Zamtel, FNB, Zanaco, and Absa.",
    "primaryColor": "#0A6E3C"
  }
}
