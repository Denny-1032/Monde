{
  "expo": {
    "name": "Monde",
    "slug": "monde",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "monde",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A6E3C"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.monde.pay"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A6E3C"
      },
      "package": "com.monde.pay",
      "permissions": [
        "CAMERA",
        "NFC",
        "VIBRATE"
      ],
      "softwareKeyboardLayoutMode": "pan",
      "allowBackup": true,
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Monde needs camera access to scan QR codes for payments."
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "monde-pay"
      },
      "SUPABASE_URL": "https://dxpjbqlgivkpbbbvhexb.supabase.co",
      "SUPABASE_ANON_KEY": "process.env.SUPABASE_ANON_KEY"
    },
    "owner": "denny-1032",
    "description": "Monde - The simplest way to send & receive money in Zambia via QR Code and Tap to Pay. Supports Airtel, MTN, Zamtel, FNB, Zanaco, and Absa.",
    "primaryColor": "#0A6E3C"
  }
}
