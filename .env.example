# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Error Tracking (optional)
EXPO_PUBLIC_SENTRY_DSN=

# Analytics (optional)
EXPO_PUBLIC_MIXPANEL_TOKEN=

# Environment: development | staging | production
APP_ENV=development

# Supabase Management API (for deploy script only — NOT used by the app)
# Get from: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_xxx

# ============================================
# Lipila Payment Gateway
# Docs: https://docs.lipila.dev
# ============================================
# Enable Lipila integration (set to 'true' when Edge Function is deployed + API keys configured)
# When disabled/unset, top-ups and withdrawals work in wallet-only mode (no real money movement)
EXPO_PUBLIC_LIPILA_ENABLED=false
#
# Mode: sandbox | live
# LIPILA_MODE=sandbox
#
# Sandbox (https://dashboard.lipila.dev → Wallets → API Keys)
# LIPILA_SANDBOX_API_KEY=Lsk_sandbox_xxx
#
# Production (https://dashboard.lipila.io → Wallets → API Keys)
# LIPILA_LIVE_API_KEY=Lsk_live_xxx
#
# Optional: Override base URLs (defaults are correct for most setups)
# LIPILA_SANDBOX_URL=https://api.lipila.dev
# LIPILA_LIVE_URL=https://blz.lipila.io
#
# Optional: Callback URL for async transaction status updates
# LIPILA_CALLBACK_URL=https://your-project.supabase.co/functions/v1/lipila-callback